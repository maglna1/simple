# ===== MiniMax API 凭据（OpenAI 兼容协议）=====
# 1. 复制本文件为 .env：cp .env.example .env
# 2. 把下面三个占位符替换为真实值
# 3. .env 已经加入 .gitignore，永远不要把真实 key 提交到 git

# 你的 MiniMax API Key（绝不能提交到任何版本控制或聊天工具）
MINIMAX_API_KEY=sk-your-api-key-here

# MiniMax 提供的 OpenAI 兼容 endpoint
MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# 要调用的模型名
MINIMAX_MODEL=MiniMax-M3